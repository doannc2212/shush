{
  "name": "shush",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun --watch scripts/build.ts",
    "build": "bun run scripts/build.ts --production",
    "check": "biome check --write src scripts",
    "lint": "biome lint src scripts",
    "format": "biome format --write src scripts",
    "type-check": "svelte-check --tsconfig ./tsconfig.json"
  },
  "dependencies": {
    "svelte": "^5.55.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "latest",
    "@types/chrome": "^0.0.304",
    "bun-plugin-svelte": "^0.0.6",
    "svelte-check": "^4.4.6",
    "typescript": "^5.8.3"
  }
}
